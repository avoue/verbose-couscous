# Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# PostgreSQL connection string. Railway provides this automatically when you
# attach a PostgreSQL plugin (as DATABASE_URL).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Amount of credits granted every 24 hours via the "Bonus" button
DAILY_BONUS_AMOUNT=100

# One-time credits granted to a referrer when someone registers via their link
REFERRAL_BONUS_AMOUNT=50

# Comma-separated Telegram user IDs allowed to use /reset_balance and /add_credits
ADMIN_IDS=123456789,987654321
